# .gitconfig

# Created by Thiago Souza (thrsouza)
# https://github.com/thrsouza/dotfiles

[user]
    name = Thiago Souza
    email = thiagosouza.me@outlook.com
    signingkey = 0000000000000000

[color]
    ui = auto

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red
    new = green

[color "status"]
    added = yellow
    changed = green
    untracked = cyan

[commit]
    gpgsign = true

[pull]
    ff = only

[init]
    defaultBranch = main
